# ─── Algorand / x402-avm ─────────────────────────────────────────────────────
# Your Algorand address (58 chars) — receives ALGO payments from agents
AVM_ADDRESS=YOUR_ALGORAND_ADDRESS_58_CHARS_AAAAAAAAAAAAAAAAAAAAAAAAAAAA

# GoPlausible x402-avm Facilitator (Algorand Testnet)
FACILITATOR_URL=https://facilitator.goplausible.xyz

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4030
SERVICE_URL=http://localhost:4030

# ─── Provider API Keys ────────────────────────────────────────────────────────
# Groq (LLM Inference — auto-routed across Llama models)
GROQ_API_KEY=gsk_...

# Deepgram (STT Nova-3 + TTS Aura-2)
DEEPGRAM_API_KEY=...

# fal.ai (Image Generation — Flux Schnell / Dev / Pro)
FAL_KEY=...

# Pinata (IPFS Decentralized Storage)
PINATA_JWT=...
PINATA_GATEWAY=your-gateway.mypinata.cloud

# HuggingFace (Serverless Inference — any model)
HF_ACCESS_TOKEN=hf_...

# Tavily (Web Search — LLM-ready results)
TAVILY_API_KEY=tvly-...

# ─── Compute (Piston — requires Docker) ──────────────────────────────────────
# Run: docker run -d -p 2000:2000 ghcr.io/engineer-man/piston
PISTON_URL=http://localhost:2000
